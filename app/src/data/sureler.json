          "translation_hint": "Anlamı: Din (hesap) gününün sahibidir.",
          "xp_reward": 10
        },
        {
          "id": "fatiha_4",
          "text": "İyyâke na'büdü ve iyyâke ____",
          "options": ["Nesta'în", "Müstakîm", "Samed"],
